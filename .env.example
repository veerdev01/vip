# ─── Telegram Bot + Userbot ──────────────────────────────
# API_ID aur API_HASH dono ke liye same use hoga
# my.telegram.org se lo
API_ID=12345678
API_HASH=your_api_hash_here

# Bot token — @BotFather se lo
BOT_TOKEN=your_bot_token_here

# Userbot: pehli baar run karne par terminal mein
# phone number + OTP maangega. Baad mein userbot_session.session
# file save ho jaayegi — dobara nahi maangega.

# ─── Admin IDs (comma separated) ─────────────────
ADMIN_IDS=123456789,987654321

# ─── MongoDB ──────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/
DB_NAME=cloud_shop

# ─── Payment Details ──────────────────────────────
UPI_ID=yourname@upi
CRYPTO_WALLET=TYourUSDTTRC20WalletHere

# ─── Telethon Session-based Numbers ───────────────────────────────
# Agar /addnumbersession use karte ho to API_ID aur API_HASH same
# Telegram account ke hone chahiye. Sessions folder mein .session
# files save hongi — inhe delete mat karna.
# sessions/ folder auto-create ho jaata hai.
